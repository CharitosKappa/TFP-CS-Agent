# ── Anthropic (Claude) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Drafting model (high quality). Triage/classification runs on a cheaper model.
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_TRIAGE_MODEL=claude-haiku-4-5

# ── Microsoft Graph (Outlook shared mailbox) ──────────────────────────
# Azure AD app registration with APPLICATION permissions: Mail.ReadWrite + Mail.Send
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
# The shared mailbox the agent reads/replies from, e.g. support@thefashionproject.gr
GRAPH_MAILBOX=
# Optional — extra domains that are "us" (mailbox aliases on a DIFFERENT domain,
# e.g. the *.onmicrosoft.com tenant domain), comma-separated. GRAPH_MAILBOX's own
# domain is always internal. Used to tell our addresses from the customer's when
# threading. e.g. INTERNAL_EMAIL_DOMAINS=thefashionproject.onmicrosoft.com
INTERNAL_EMAIL_DOMAINS=

# ── Shopify Admin API ─────────────────────────────────────────────────
# Dev Dashboard custom app. The Admin API token is fetched at runtime via the
# OAuth client_credentials grant from the Client ID/Secret below (no static token).
# Requires the app + store to be in the SAME Dev Dashboard org, with scopes
# (read_orders, read_customers, read_products, read_discounts, and read_price_rules
# for legacy discount codes) configured and the app installed.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2025-10

# ── Odoo (self-hosted) — read-only RMA/order lookups via JSON-RPC ─────
# The agent connects with a DEDICATED, read-only Odoo user (not your admin).
# Authenticate with an API key, not a password: in Odoo open
#   Preferences → Account Security → New API Key
# Use HTTPS only — the API key travels in the request body.
ODOO_URL=https://staging-odoo.thefashionproject.gr
# Odoo is multi-db; this must be the exact database name.
ODOO_DB=
# Login of the dedicated read-only API user.
ODOO_API_USER=
# API key for that user (used in place of the password).
ODOO_API_KEY=

# ── Microsoft Planner — follow-up / escalation task board ─────────────
# Uses the existing Graph app (app-only) + Tasks.ReadWrite.All. Optional: leave
# blank to disable Planner task creation. Get the planId from the Planner web URL
# (…/plan/<planId>/…) and the bucketId from the plan's buckets. Not secrets.
PLANNER_PLAN_ID=
# Target bucket for new tasks (e.g. the "To do" column). Optional.
PLANNER_BUCKET_ID=
