# ── Anthropic (Claude) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Drafting model (high quality). Triage/classification runs on a cheaper model.
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_TRIAGE_MODEL=claude-haiku-4-5

# ── Microsoft Graph (Outlook shared mailbox) ──────────────────────────
# Azure AD app registration with APPLICATION permissions: Mail.ReadWrite + Mail.Send
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
# The shared mailbox the agent reads/replies from, e.g. support@thefashionproject.gr
GRAPH_MAILBOX=
# Optional — only for webhook push (not needed for manual sync). Public HTTPS endpoint
# pointing at /api/graph/notifications
GRAPH_WEBHOOK_NOTIFICATION_URL=
# A random secret you choose; verified on every incoming notification.
GRAPH_WEBHOOK_CLIENT_STATE=

# ── Shopify Admin API ─────────────────────────────────────────────────
# Dev Dashboard custom app. The Admin API token is fetched at runtime via the
# OAuth client_credentials grant from the Client ID/Secret below (no static token).
# Requires the app + store to be in the SAME Dev Dashboard org, with scopes
# (read_orders, read_customers, read_products, read_discounts, and read_price_rules
# for legacy discount codes) configured and the app installed.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2025-10

# ── Database (PostgreSQL) ─────────────────────────────────────────────
# Matches the local dev DB in docker-compose.yml (`docker compose up -d`).
DATABASE_URL=postgresql://tfp:tfp_local_dev@localhost:5432/tfp_cs_agent?schema=public

# ── Auth — Entra ID (Azure AD) SSO for the dashboard ──────────────────
# `openssl rand -base64 32`
AUTH_SECRET=
# In production behind a proxy, set the public URL (or AUTH_TRUST_HOST=true).
AUTH_URL=
# Azure AD app registration (can reuse the tenant from GRAPH_*). Redirect URI:
#   <AUTH_URL>/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# https://login.microsoftonline.com/<tenant-id>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=
# Comma-separated allowlist of reviewer emails. Empty = any user in the tenant.
ALLOWED_REVIEWERS=

# ── Machine-route secret (ingest/process/health) ──────────────────────
# Required to call POST /api/ingest, /api/process and detailed GET /api/health.
# Send as `Authorization: Bearer <secret>` or `x-internal-secret`. `openssl rand -hex 32`
INTERNAL_API_SECRET=

# ── Data retention (GDPR) ─────────────────────────────────────────────
# Days to keep a conversation after its last activity (set per DPO policy).
RETENTION_DAYS=730
